<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">

    <Dialog id="donorDialog" title="Donor Details" contentWidth="500px" draggable="true" resizable="true">
        <content>
            <form:SimpleForm editable="false" layout="ResponsiveGridLayout"
                             labelSpanL="4" labelSpanM="4" labelSpanS="12">
                <Label text="Donor ID"/>
                <Text text="{DonorId}"/>
                <Label text="Full Name"/>
                <Text text="{FirstName} {LastName}"/>
                <Label text="Blood Group"/>
                <ObjectStatus text="{BloodGroup}" state="Success" icon="sap-icon://heart"/>
                <Label text="Phone"/>
                <Text text="{Phone}"/>
                <Label text="Email"/>
                <Text text="{Email}"/>
                <Label text="City"/>
                <Text text="{City}, {State}"/>
                <Label text="Status"/>
                <ObjectStatus text="{Status}" state="{= ${Status} === 'Active' ? 'Success' : 'Error' }"/>
            </form:SimpleForm>
        </content>
        <beginButton>
            <Button text="Edit" type="Emphasized" press="onEditDonorFromDialog"/>
        </beginButton>
        <endButton>
            <Button text="Close" press="onCloseDonorDialog"/>
        </endButton>
    </Dialog>

</core:FragmentDefinition>
