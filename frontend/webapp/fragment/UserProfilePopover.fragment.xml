<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <ResponsivePopover
        id="userProfilePopover"
        title="User Profile"
        placement="Bottom"
        contentWidth="320px"
        class="llProfilePopover sapUiContentPadding">
        <content>
            <VBox alignItems="Center" justifyContent="Center" class="sapUiSmallMarginBottom sapUiMediumMarginTop">
                <Avatar
                    initials="BA"
                    displaySize="L"
                    class="sapUiSmallMarginBottom"
                    backgroundColor="Accent6"/>
                <Title text="Blood Bank Administrator" level="H3" titleStyle="H3" class="llTextBold"/>
                <Text text="admin@lifelink.org" class="sapUiTinyMarginTop"/>
                <ObjectStatus text="Role: System Superuser" state="Success" class="sapUiTinyMarginTop"/>
            </VBox>
            <List>
                <StandardListItem title="Organization: Central Blood Bank" icon="sap-icon://official-service" type="Inactive"/>
                <StandardListItem title="Location: New York" icon="sap-icon://map-2" type="Inactive"/>
            </List>
            <Button
                id="logoutButton"
                text="Log Out"
                type="Reject"
                icon="sap-icon://log"
                press="onLogOut"
                class="llBtnFullWidth sapUiMediumMarginTop"/>
        </content>
    </ResponsivePopover>
</core:FragmentDefinition>
