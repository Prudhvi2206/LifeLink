<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="confirmDialog" title="{confirmTitle}" type="Message">
        <content>
            <VBox class="sapUiSmallMargin">
                <Text text="{confirmMessage}"/>
            </VBox>
        </content>
        <beginButton>
            <Button text="Confirm" type="Emphasized" press="onConfirmAction"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCancelConfirm"/>
        </endButton>
    </Dialog>

</core:FragmentDefinition>
